{
  "name": "TCT",
  "description": "A fast WA bot built with Go",
  "keywords": [
    "tct",
    "go",
    "whatsapp",
    "bot"
  ],
  "stack": "heroku-24",
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp session ID (REQUIRED)",
      "value": "",
      "required": true
    },
    "PREFIX": {
      "description": "Command prefixes (comma separated, leave empty for no prefix)",
      "value": ".",
      "required": false
    },
    "TIMEZONE": {
      "description": "Your timezone (e.g., Africa/Nairobi, America/New_York)",
      "value": "Africa/Nairobi",
      "required": false
    },
    "POSTGRES_URL": {
      "description": "Full PostgreSQL connection URL. Example: postgresql://username:password@host:5432/database",
      "value": "",
      "required": false
    },
    "POSTGRES_SYNC_INTERVAL": {
      "description": "Postgres sync interval in seconds. Example: 60 = every 60 seconds",
      "value": "60",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
